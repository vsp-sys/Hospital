rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return true; // Set to true to authorize standard queries in sandbox/preview environments
    }

    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'superadmin@medcore.com' || 
        request.auth.token.email == 'vismayp1014@gmail.com' ||
        request.auth.token.email == '123raj4030@sjcem.edu.in' ||
        request.auth.token.email == 'rajpatil8837@gmail.com' ||
        request.auth.token.email == 'shlokpatil7076@gmail.com'
      );
    }

    function isCurrentBranchAdminActive() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/branchAdmins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/branchAdmins/$(request.auth.uid)).data.status == 'Active';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Collection Rules
    
    match /test/{document} {
      allow read: if true;
    }
    
    match /hospitals/{hospitalId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive();
    }

    match /beds/{bedId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive();
    }

    match /doctors/{doctorId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive();
    }

    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || (isSignedIn() && request.auth.uid == patientId);
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /invoices/{invoiceId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    // Branch Admin Enrollment collection
    match /branchAdmins/{adminId} {
      allow read: if isSignedIn();
      // Allow any Google user to submit a pending registration request for themselves
      allow create: if isSignedIn() && 
                    request.resource.data.id == adminId && 
                    request.resource.data.status == 'Pending' &&
                    (request.auth == null || request.resource.data.email == request.auth.token.email);
      // Status toggle, de-authorization is reserved to Super Admin
      allow update, delete: if isSuperAdmin() || 
                            (request.auth != null && 
                             (request.auth.uid == adminId || request.auth.token.email == resource.data.email) && 
                             request.resource.data.status == resource.data.status);
    }

    match /auditLogs/{logId} {
      // Compliance audits can be added by any signed in portal, but never updated/deleted (immutable)
      allow read: if isSuperAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /prescriptions/{prescriptionId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /labOrders/{orderId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /tickets/{ticketId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /vitals/{vitalId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /fluids/{fluidId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /medications/{medId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /handoffs/{handoffId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || isCurrentBranchAdminActive() || isSignedIn();
    }

    match /licenses/{licenseId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isSignedIn();
    }
  }
}
